# ──────────────────────────────────────────────────────────────────────────────
# Step-CA UI — environment configuration template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# Or run `make setup` to copy it and generate secrets/ automatically.
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# Core deployment
# ──────────────────────────────────────────────────────────────────────────────

# Host IP
# Used as Subject Alternative Name in the self-signed TLS certificate
# and as a DNS name for step-ca. Set this to your server's reachable IP.
HOST_IP=192.168.1.100

# External HTTPS port
# Host port for the web UI. Use 8443 if 443 is already occupied.
UI_HTTPS_PORT=443

# Time zone
# Used by all containers for logs and UI timestamps.
# Examples: UTC, Europe/London, America/New_York, Asia/Tokyo.
TZ=UTC

# Initial admin password (optional, one-shot)
# Picked up by entrypoint on first boot to create the admin user.
# After successful boot you can safely remove this line.
# If left empty, defaults to "Admin123!" — CHANGE IT IMMEDIATELY.
# STEPUI_ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# step-ca connection
# ──────────────────────────────────────────────────────────────────────────────

# step-ca API base URL (must be reachable from inside the step-ui container).
CA_URL=https://step-ca:9443

# Path to the step-ca root certificate inside the container.
# Used by the Go app and all `step` CLI calls to verify the CA.
# Default: /home/step/certs/root_ca.crt (matches the step-ca volume mount).
# ROOT_CERT=/home/step/certs/root_ca.crt

# Root CA fingerprint (SHA-256 of the root cert DER; PUBLIC, non-secret).
# When set and $ROOT_CERT is absent or empty, the entrypoint downloads the root
# cert from step-ca on startup (30 retries × 1 s). On failure, startup continues
# with a warning. Get this value from step-ca logs or:
#   step certificate fingerprint /path/to/root_ca.crt
# CA_FINGERPRINT=

# Inline root CA PEM (highest-precedence root-trust method).
# When set, the entrypoint writes this PEM to $ROOT_CERT at startup.
# Use for ECS / Kubernetes deployments where a volume mount is not available.
# Overrides CA_FINGERPRINT. Keep this on one line (no embedded newlines) or
# use a multiline block if your secrets manager supports it.
# CA_ROOT_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# Provisioner identifier (used for certificate requests).
PROVISIONER=admin

# Provisioner password (plain-env fallback — prefer secrets/ca_password).
# Stored in secrets/ca_password (created by `make setup`). The value here is
# only used if you run without Docker secrets. Min 8 chars.
# Generate: openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24
# CA_PASSWORD=change-me-min-8-chars

# Path to the provisioner password file inside the container.
# The entrypoint writes CA_PASSWORD here when the file does not yet exist.
# PASSWORD_FILE=/opt/step-ui/data/provisioner_password

# Step-CA Docker image
# Pinned by default for reproducible updates. Test before changing.
STEP_CA_IMAGE=smallstep/step-ca:0.30.2

# Step-CA certificate duration limits
# Applied to the default provisioner during clean step-ca initialization.
# 8760h = 1 year, 87600h = 10 years.
STEPCA_DEFAULT_TLS_CERT_DURATION=8760h
STEPCA_MAX_TLS_CERT_DURATION=87600h

# ──────────────────────────────────────────────────────────────────────────────
# TLS — UI serving certificate
# ──────────────────────────────────────────────────────────────────────────────
# UI_TLS_MODE controls how the UI's own HTTPS certificate is obtained:
#
#   self-signed (default)
#     Generate a 10-year self-signed cert on first boot if SSL_CERT is absent.
#     SANs: IP:HOST_IP, DNS:localhost, and DNS:UI_HOSTNAME (when set).
#     This is the original docker-compose / dev behaviour — unchanged when
#     UI_TLS_MODE is unset.
#
#   provided
#     Do nothing. Expect the operator to mount a cert+key at SSL_CERT/SSL_KEY
#     before the container starts (volume mount, init container, etc.).
#
#   stepca
#     Request a signed leaf cert from the step-ca managed by this UI.
#     Retried up to 30 times (1 s apart); falls back to self-signed on failure.
#     Requires CA_URL, ROOT_CERT (or CA_FINGERPRINT/CA_ROOT_CERT_PEM), and
#     PASSWORD_FILE to be ready — the entrypoint ordering guarantees this.
#     After a successful issue, starts `step ca renew --daemon` in the
#     background so the cert is renewed automatically. The Go hot-reloader
#     picks up the renewed cert on the next TLS handshake with zero restart.
#     Note: the renewal daemon is NOT supervised — if it exits it is not
#     restarted. The serving app (PID 1) is unaffected.
UI_TLS_MODE=self-signed

# Hostname for the UI's TLS certificate.
#   self-signed: added as an extra DNS SAN alongside HOST_IP and localhost.
#   stepca:      used as the CN/SAN requested from the CA.
#                Falls back to `hostname -f` when empty.
# UI_HOSTNAME=ui.internal.example.com

# Paths to the serving TLS certificate and key inside the container.
# These paths are read by the Go app regardless of UI_TLS_MODE.
# SSL_CERT=/opt/step-ui/ssl/server.crt
# SSL_KEY=/opt/step-ui/ssl/server.key

# Force TLS on or off, overriding the auto-detect behaviour.
#   true  — always serve HTTPS even if SSL_CERT does not exist yet.
#   false — always serve plain HTTP (not suitable for production).
#   (empty, default) — auto-detect: serve HTTPS if SSL_CERT exists on disk.
# USE_HTTPS=

# ──────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────────
# The entrypoint constructs DATABASE_URL from POSTGRES_* parts when DATABASE_URL
# is not set. Use DATABASE_URL directly for RDS, managed PG, or Kubernetes.

# Full PostgreSQL DSN (takes precedence over all POSTGRES_* parts below).
# DATABASE_URL=postgres://stepui:password@postgres:5432/stepui?sslmode=disable

# Individual connection parts (used only when DATABASE_URL is not set).
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_USER=stepui
# POSTGRES_DB=stepui

# PostgreSQL password (plain-env fallback — prefer secrets/postgres_password).
# Stored in secrets/postgres_password (created by `make setup`). Min 8 chars.
# Used by both the postgres container and step-ui (via entrypoint).
# POSTGRES_PASSWORD=change-me-min-8-chars

# ──────────────────────────────────────────────────────────────────────────────
# Application security
# ──────────────────────────────────────────────────────────────────────────────

# Session/CSRF signing key (stored in secrets/secret_key; created by `make setup`).
# The value here is only used if you run without Docker secrets (plain-env fallback).
# Min 32 chars, recommended 48. The app REFUSES to start with the default or a
# key shorter than 32 chars. Keep this SECRET — it signs all session cookies.
# Generate: openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 48
# SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Secure session cookie
# Keep true for HTTPS production. Set false only for local HTTP development.
SESSION_SECURE=true

# HTTP Strict Transport Security (HSTS)
# Keep false for the default self-signed certificate.
# Enable only with a trusted TLS certificate.
ENABLE_HSTS=false

# ──────────────────────────────────────────────────────────────────────────────
# Reverse-proxy trust / RealIP
# ──────────────────────────────────────────────────────────────────────────────
# Set true only when the app runs behind a trusted reverse proxy (nginx,
# Traefik, etc.) that strips/rewrites X-Forwarded-For before forwarding.
# When false (default), RemoteAddr is always the real socket peer, so the
# rate limiter and auth log cannot be spoofed by crafted headers.
TRUST_PROXY=false

# ──────────────────────────────────────────────────────────────────────────────
# Local password login (break-glass)
# ──────────────────────────────────────────────────────────────────────────────
# Set false to disable the username/password form (OIDC must be enabled first).
# Keep true while setting up OIDC so you don't lock yourself out.
LOCAL_LOGIN_ENABLED=true

# ──────────────────────────────────────────────────────────────────────────────
# JumpCloud OIDC SSO
# ──────────────────────────────────────────────────────────────────────────────
# Fill these from your JumpCloud OIDC application settings.
# OIDC_ENABLED=false by default — existing deployments are unaffected.
# Steps to configure in JumpCloud:
#   1. SSO → + Add New Application → Custom OIDC App
#   2. Redirect URI: https://<your-host>/auth/oidc/callback
#   3. Copy Client ID and Client Secret below.
#   4. Add group attributes (Attribute Name = "groups").
#   5. Set OIDC_GROUP_ADMIN / MANAGER / VIEWER to the JumpCloud group names.
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://oauth.id.jumpcloud.com/
OIDC_CLIENT_ID=your-jumpcloud-client-id
OIDC_CLIENT_SECRET=your-jumpcloud-client-secret
OIDC_REDIRECT_URL=https://your-host/auth/oidc/callback

# Claim name in the ID token that carries group membership (JumpCloud default: "groups").
OIDC_GROUP_CLAIM=groups

# Map JumpCloud group names to Step-CA UI roles. Precedence: admin > manager > viewer.
# Leave a mapping empty to skip that role level.
OIDC_GROUP_ADMIN=step-ca-admins
OIDC_GROUP_MANAGER=step-ca-managers
OIDC_GROUP_VIEWER=step-ca-viewers

# Role to assign when no group matches. Leave empty to deny access (recommended).
OIDC_DEFAULT_ROLE=

# When true (default), the role is updated on every OIDC login so group membership
# stays authoritative. Set false to preserve manually assigned roles.
OIDC_SYNC_ROLE=true
