# ──────────────────────────────────────────────────────────────────────────────
# Step-CA UI — environment configuration template
#
# EN: Copy this file to .env and fill in your values:
#       cp .env.example .env
#       nano .env
#     Or run sudo ./install.sh to do it automatically.
#
# RU: Скопируйте этот файл в .env и заполните своими значениями:
#       cp .env.example .env
#       nano .env
#     Либо запустите sudo ./install.sh для автоматической настройки.
# ──────────────────────────────────────────────────────────────────────────────

# Host IP / Адрес хоста
# EN: Used as Subject Alternative Name in the self-signed TLS certificate
#     and as a DNS name for step-ca. Put your server's reachable IP here.
# RU: Используется как SAN в self-signed TLS-сертификате и как DNS-имя для
#     step-ca. Укажите IP сервера, по которому он будет доступен.
HOST_IP=192.168.1.100

# External HTTPS port / Внешний HTTPS-порт
# EN: Host port for the web UI. Use 8443 if 443 is already occupied.
# RU: Порт на хосте для веб-интерфейса. Используйте 8443, если 443 уже занят.
UI_HTTPS_PORT=443

# Provisioner identifier / Идентификатор provisioner'а
# EN: Identity for the default step-ca provisioner.
# RU: Идентификатор для дефолтного provisioner'а step-ca.
PROVISIONER=admin

# Step-CA provisioner password / Пароль provisioner'а step-ca
# EN: Min 8 chars. Use install.sh to auto-generate, or:
#       openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24
# RU: Минимум 8 символов. Сгенерируйте через install.sh или вручную:
#       openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24
CA_PASSWORD=change-me-min-8-chars

# Step-CA Docker image / Docker image для step-ca
# EN: Pinned by default for reproducible updates. Test before changing.
# RU: По умолчанию закреплён для воспроизводимых обновлений. Меняйте только после теста.
STEP_CA_IMAGE=smallstep/step-ca:0.30.2

# Session/CSRF signing key / Ключ подписи сессий и CSRF
# EN: Min 32 chars, recommended 48. Keep this SECRET — leaking it allows
#     forging sessions of any user. Generate with:
#       openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 48
# RU: Минимум 32 символа, рекомендуется 48. Держите его В СЕКРЕТЕ —
#     утечка позволяет подделать сессию любого пользователя. Генерация:
#       openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 48
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Secure session cookie / Secure-флаг cookie сессии
# EN: Keep true for HTTPS production. Set false only for local HTTP development.
# RU: Оставляйте true для HTTPS production. false — только для локальной HTTP-разработки.
SESSION_SECURE=true

# HTTP Strict Transport Security / HSTS
# EN: Keep false for the default self-signed certificate. Enable only with a trusted TLS certificate.
# RU: Оставляйте false для дефолтного self-signed сертификата. Включайте только с доверенным TLS-сертификатом.
ENABLE_HSTS=false

# PostgreSQL password / Пароль PostgreSQL
# EN: Used by both the database and the application. Min 8 chars.
# RU: Используется и базой, и приложением. Минимум 8 символов.
POSTGRES_PASSWORD=change-me-min-8-chars

# Time zone / Часовой пояс
# EN: Used by all containers for logs and UI timestamps. Example:
#     UTC, Europe/London, America/New_York, Europe/Moscow.
# RU: Используется контейнерами для логов и времени в интерфейсе. Примеры:
#     UTC, Europe/London, America/New_York, Europe/Moscow.
TZ=UTC

# Step-CA certificate duration limits / Лимиты срока сертификатов step-ca
# EN: Applied to the default provisioner during clean step-ca initialization.
#     8760h = 1 year, 87600h = 10 years.
# RU: Применяется к дефолтному provisioner'у при чистой инициализации step-ca.
#     8760h = 1 год, 87600h = 10 лет.
STEPCA_DEFAULT_TLS_CERT_DURATION=8760h
STEPCA_MAX_TLS_CERT_DURATION=87600h

# Initial admin password / Пароль первого admin'а (опционально)
# EN: One-shot — picked up by entrypoint on first boot to create the admin
#     user. After successful boot you can safely remove this line.
#     If left empty, defaults to "Admin123!" (CHANGE IT IMMEDIATELY).
# RU: Одноразово — entrypoint при первом запуске создаст admin'а с этим
#     паролем. После успешной загрузки строку можно удалить.
#     Если не задан, по умолчанию "Admin123!" (СРАЗУ СМЕНИТЕ!).
# STEPUI_ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# Reverse-proxy trust / RealIP
# ──────────────────────────────────────────────────────────────────────────────
# EN: Set true only when the app runs behind a trusted reverse proxy (nginx,
#     Traefik, etc.) that strips/rewrites X-Forwarded-For before forwarding.
#     When false (default), RemoteAddr is always the real socket peer, so the
#     rate limiter and auth log cannot be spoofed by crafted headers.
# RU: Включайте только при наличии доверенного reverse-proxy, который очищает
#     X-Forwarded-For. По умолчанию false — IP всегда берётся из TCP-соединения.
TRUST_PROXY=false

# ──────────────────────────────────────────────────────────────────────────────
# Local password login (break-glass)
# ──────────────────────────────────────────────────────────────────────────────
# EN: Set false to disable the username/password form (OIDC must be enabled).
#     Keep true while setting up OIDC so you don't lock yourself out.
# RU: false — отключить форму логина/пароля (требует включённого OIDC).
#     Оставляйте true при первоначальной настройке OIDC.
LOCAL_LOGIN_ENABLED=true

# ──────────────────────────────────────────────────────────────────────────────
# JumpCloud OIDC SSO
# ──────────────────────────────────────────────────────────────────────────────
# EN: Fill these from your JumpCloud OIDC application settings.
#     OIDC_ENABLED=false by default — existing deployments are unaffected.
#     Steps to configure in JumpCloud:
#       1. SSO → + Add New Application → Custom OIDC App
#       2. Redirect URI: https://<your-host>/auth/oidc/callback
#       3. Copy Client ID and Client Secret below.
#       4. Add group attributes (Attribute Name = "groups").
#       5. Set OIDC_GROUP_ADMIN / MANAGER / VIEWER to the JumpCloud group names.
#
# RU: Заполняется из настроек OIDC-приложения JumpCloud.
#     По умолчанию OIDC_ENABLED=false — существующие развёртывания не затронуты.
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://oauth.id.jumpcloud.com/
OIDC_CLIENT_ID=your-jumpcloud-client-id
OIDC_CLIENT_SECRET=your-jumpcloud-client-secret
OIDC_REDIRECT_URL=https://your-host/auth/oidc/callback

# EN: Claim name in the ID token that carries group membership (JumpCloud default: "groups").
# RU: Название claim'а с группами в ID token (JumpCloud по умолчанию: "groups").
OIDC_GROUP_CLAIM=groups

# EN: Map JumpCloud group names to Step-CA UI roles. Precedence: admin > manager > viewer.
#     Leave a mapping empty to skip that role level.
# RU: Имена групп JumpCloud → роли Step-CA UI. Приоритет: admin > manager > viewer.
OIDC_GROUP_ADMIN=step-ca-admins
OIDC_GROUP_MANAGER=step-ca-managers
OIDC_GROUP_VIEWER=step-ca-viewers

# EN: Role to assign when no group matches. Leave empty to deny access (recommended).
# RU: Роль при отсутствии совпадений. Оставьте пустым для запрета (рекомендуется).
OIDC_DEFAULT_ROLE=

# EN: When true (default), the role is updated on every OIDC login so JumpCloud
#     groups remain authoritative. Set false to preserve manually assigned roles.
# RU: При true (по умолчанию) роль обновляется при каждом входе (группы JumpCloud
#     авторитативны). false — сохранять роли, назначенные вручную.
OIDC_SYNC_ROLE=true
